{
	"name": "mini-crm-api",
	"version": "1.0.0",
	"description": "Portfolio backend API: Mini-CRM built with Express + TypeScript + Drizzle + PostgreSQL",
	"main": "dist/index.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/express": "^5.0.6",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/uuid": "^10.0.0",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"ts-node-dev": "^2.0.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"express": "^5.2.1",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"uuid": "^14.0.0",
		"zod": "^4.3.6"
	}
}
